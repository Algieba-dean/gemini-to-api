# Copy to .env and fill in your values (.env is gitignored).
# Used by docker-compose.prod.yml and the Nginx config template.

# Public hostname served by Nginx (your domain).
SERVER_NAME=gemini-api.example.com

# Host directory that contains the TLS certificate and key.
# Mounted read-only into the Nginx container at /etc/nginx/ssl.
# Example: a Cloudflare Origin Certificate directory, or ./nginx/ssl
CERT_DIR=./nginx/ssl

# Certificate / key filenames inside CERT_DIR.
SSL_CERT_FILE=fullchain.pem
SSL_CERT_KEY_FILE=privkey.pem

# Upstream application address (must match host/port in config.json).
APP_HOST=127.0.0.1
APP_PORT=8081

# External API key clients must send as: Authorization: Bearer <API_KEY>
# Generate a strong one with:  openssl rand -hex 24
API_KEY=change-me-generate-with-openssl-rand-hex-24
